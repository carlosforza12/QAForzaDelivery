# OpenRouter API Key (for AI-generated documentation)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Modelo a usar en OpenRouter. Los gratuitos llevan el sufijo :free
# Ver lista completa en: https://openrouter.ai/models?q=free
# Ejemplos gratuitos:
#   meta-llama/llama-3.1-8b-instruct:free
#   google/gemma-3-12b-it:free
#   deepseek/deepseek-chat-v3-0324:free
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Atlassian Confluence (optional, for publishing results)
ATLASSIAN_SYNC_ENABLED=false
ATLASSIAN_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net

# Confluence specific
CONFLUENCE_SYNC_ENABLED=false
CONFLUENCE_SPACE_KEY=YOUR_SPACE_KEY
CONFLUENCE_PARENT_PAGE_ID=0000000000
CONFLUENCE_PAGE_TITLE_PREFIX=Informe Automatizacion

# ── Reporte de Cierre de Calidad (PDF) ──────────────────────────────────────
# Genera reporte-cierre.docx + reporte-cierre.pdf al finalizar la ejecución
# Desactivar durante desarrollo para evitar generación automática al terminar cada ejecución
FINAL_REPORT_ENABLED=false
PDF_REPORT_ENABLED=true

# Defectos detectados por severidad
DEFECTOS_CRITICOS=0
DEFECTOS_ALTOS=0
DEFECTOS_MEDIOS=0
DEFECTOS_BAJOS=0

# Defectos cerrados por severidad
DEFECTOS_CRITICOS_CERRADOS=0
DEFECTOS_ALTOS_CERRADOS=0
DEFECTOS_MEDIOS_CERRADOS=0
DEFECTOS_BAJOS_CERRADOS=0

# Defectos diferidos por severidad
DEFECTOS_CRITICOS_DIFERIDOS=0
DEFECTOS_ALTOS_DIFERIDOS=0
DEFECTOS_MEDIOS_DIFERIDOS=0
DEFECTOS_BAJOS_DIFERIDOS=0

# Justificación para defectos diferidos (se muestra en la tabla de defectos)
DEFECTOS_DIFERIDOS_JUSTIFICACION=

# Base URL for tests (UI Playwright)
BASE_URL=https://qa.portal.forzadelivery.com/

# ── Servicio de devolución corporativo (UI) ─────────────────────────────────
# Se referencian desde el .feature con ENV:<VARIABLE> para no exponer datos
# sensibles o personales dentro del repositorio.
DEVOLUCION_GT_CORP_CODIGO=your-gt-corporate-code
DEVOLUCION_GT_CORP_USUARIO=your-gt-corporate-user
DEVOLUCION_GT_CORP_CONTRASENIA=your-gt-corporate-password
DEVOLUCION_GT_NOMBRE_CONTACTO=Nombre Apellido
DEVOLUCION_GT_TELEFONO=00000000
DEVOLUCION_GT_DIRECCION_REMITENTE=Direccion de prueba Guatemala

DEVOLUCION_HN_CORP_CODIGO=your-hn-corporate-code
DEVOLUCION_HN_CORP_USUARIO=your-hn-corporate-user
DEVOLUCION_HN_CORP_CONTRASENIA=your-hn-corporate-password
DEVOLUCION_HN_NOMBRE_CONTACTO=Nombre Apellido
DEVOLUCION_HN_TELEFONO=00000000
DEVOLUCION_HN_DIRECCION_REMITENTE=Direccion de prueba Honduras

DEVOLUCION_SV_CORP_CODIGO=your-sv-corporate-code
DEVOLUCION_SV_CORP_USUARIO=your-sv-corporate-user
DEVOLUCION_SV_CORP_CONTRASENIA=your-sv-corporate-password
DEVOLUCION_SV_NOMBRE_CONTACTO=Nombre Apellido
DEVOLUCION_SV_TELEFONO=00000000
DEVOLUCION_SV_DIRECCION_REMITENTE=Direccion de prueba El Salvador

# ── API Forza Delivery ────────────────────────────
# URL base por ambiente
API_STAGING_URL=https://apicore.forzadeliveryexpress.com/
API_QA_URL=https://sandbox.apicore.forzadelivery.io:40467/
API_QA_AWS_URL=https://qa-apicore.forzadeliveryexpress.com/
API_PROD_URL=https://apicore.forzadelivery.io/

# Credenciales del cliente (CodApp + SecretKey)
API_COD_APP=your-cod-app-id
API_SECRET_KEY=your-secret-key
