# OpenRouter API Key (for AI-generated documentation)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Modelo a usar en OpenRouter. Los gratuitos llevan el sufijo :free
# Ver lista completa en: https://openrouter.ai/models?q=free
# Ejemplos gratuitos:
#   meta-llama/llama-3.1-8b-instruct:free
#   google/gemma-3-12b-it:free
#   deepseek/deepseek-chat-v3-0324:free
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Atlassian Confluence (optional, for publishing results)
ATLASSIAN_SYNC_ENABLED=false
ATLASSIAN_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net

# Confluence specific
CONFLUENCE_SYNC_ENABLED=false
CONFLUENCE_SPACE_KEY=YOUR_SPACE_KEY
CONFLUENCE_PARENT_PAGE_ID=0000000000
CONFLUENCE_PAGE_TITLE_PREFIX=Informe Automatizacion

# Base URL for tests (UI Playwright)
BASE_URL=https://qa.portal.forzadelivery.com/

# ── API Forza Delivery ────────────────────────────
# URL base por ambiente
API_STAGING_URL=https://apicore.forzadeliveryexpress.com/
API_QA_URL=https://sandbox.apicore.forzadelivery.io:40467/
API_QA_AWS_URL=https://qa-apicore.forzadeliveryexpress.com/
API_PROD_URL=https://apicore.forzadelivery.io/

# Credenciales del cliente (CodApp + SecretKey)
API_COD_APP=your-cod-app-id
API_SECRET_KEY=your-secret-key
